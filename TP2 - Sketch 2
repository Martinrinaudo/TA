#include <WiFi.h>
#include <ThingSpeak.h>
#include <ArduinoOTA.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// --- CONFIGURACIÓN ---
const char* ssid = "Wokwi-GUEST";
const char* password = "";
unsigned long Channel = 3365192;
const char* ReadAPIKey = "YG5NS6WNVP60V4M6";
WiFiClient client;

// --- HARDWARE ---
#define PIN_PUSH 19 // Botón para cambiar de pantalla[cite: 7]
#define I2C_ADDRESS 0x3C
Adafruit_SSD1306 display(128, 64, &Wire, -1);

// --- VARIABLES ---
float campo1, temp, hum;
long uptime;
String statusTS = "";
int pantalla = 0;
unsigned long ultimaLectura = 0;
bool btnAnt = HIGH;

void actualizarDisplay();

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);
  pinMode(PIN_PUSH, INPUT_PULLUP);

  if(!display.begin(SSD1306_SWITCHCAPVCC, I2C_ADDRESS)) while(1);
  display.setTextColor(WHITE);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) delay(500);

  // --- CONFIGURACIÓN OTA (Requisito punto 2) ---
  ArduinoOTA.setHostname("ESP32-TP2-LECTOR");
  ArduinoOTA.onStart([]() {
    display.clearDisplay();
    display.setCursor(0, 20);
    display.println("ACTUALIZANDO...");
    display.display();
  });
  ArduinoOTA.begin();

  ThingSpeak.begin(client);
}

void loop() {
  ArduinoOTA.handle(); // Manejo de OTA[cite: 4]
  unsigned long ahora = millis();

  // 1. CAMBIO DE PANTALLA MANUAL (Pin 19)
  bool btnAct = digitalRead(PIN_PUSH);
  if (btnAct == LOW && btnAnt == HIGH) {
    pantalla = (pantalla + 1) % 3;
    actualizarDisplay();
    delay(200);
  }
  btnAnt = btnAct;

  // 2. LECTURA DE THINGSPEAK (Cada 16s)
  if (ahora - ultimaLectura >= 16000) {
    int code = ThingSpeak.readMultipleFields(Channel, ReadAPIKey); // Eficiente[cite: 6]
    if (code == 200) {
      campo1 = ThingSpeak.getFieldAsFloat(1);
      temp   = ThingSpeak.getFieldAsFloat(2);
      hum    = ThingSpeak.getFieldAsFloat(3);
      uptime = ThingSpeak.getFieldAsLong(4);
      statusTS = ThingSpeak.getStatus();
    }
    actualizarDisplay();
    ultimaLectura = ahora;
  }
}

void actualizarDisplay() {
  display.clearDisplay();
  display.setCursor(0,0);
  
  if (pantalla == 0) {
    display.println("PAG 1: GENERAL");
    display.printf("\nValor: %.1f\n", campo1);
    display.printf("Uptime: %ld s", uptime);
  } else if (pantalla == 1) {
    display.println("PAG 2: SENSORES");
    display.printf("\nTemp: %.2f C\n", temp);
    display.printf("Hum:  %.2f %%", hum);
  } else {
    display.println("PAG 3: ESTADO");
    display.setCursor(0, 20);
    display.println(statusTS);
  }
  display.display();
}
