#include <WiFi.h>
#include <ThingSpeak.h>
#include <DHT.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SH110X.h> // Cambiada la librería al modelo SH110X

// --- CONFIGURACIÓN WIFI Y THINGSPEAK ---
const char* ssid = "Moto Edge 40";
const char* password = "timoteoyclara";
unsigned long Channel = 3370344;
const char* APIKey = "0F6V5EO1Q5K9WTZ6";
WiFiClient client;

// --- PINES (Mantengo los del primer código pero con el pulsador en 19 según tu placa) ---
#define DHTPIN 33
#define DHTTYPE DHT22
DHT dht(DHTPIN, DHTTYPE);
#define PIN_PUSH 19 // Cambiado a 19 según el pinout de tu cátedra
#define I2C_ADDRESS 0x3C

// --- DISPLAY SH1106G (Configuración exacta de tu código que sí anda) ---
const int SCREEN_WIDTH = 128;
const int SCREEN_HEIGHT = 64;
Adafruit_SH1106G display = Adafruit_SH1106G(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire);

// --- ESTADO ---
const char* estados[] = {"No disponible", "En reparacion", "Habilitado", "Fuera de servicio"};
int indiceEstado = 0;
unsigned long ultimaVezThingSpeak = 0;
const unsigned long intervaloThingSpeak = 16000;
bool btnAnt = HIGH;
unsigned long btnUltimoTiempo = 0;
const int DEBOUNCE_MS = 50;

void setup() {
  Serial.begin(115200);
  dht.begin();
  Wire.begin(21, 22);

  // Inicialización específica para SH1106G
  display.begin(I2C_ADDRESS, true);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.display();

  Serial.print("Conectando a WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi conectado!");
  
  ThingSpeak.begin(client);
  pinMode(PIN_PUSH, INPUT_PULLUP);
}

void loop() {
  unsigned long ahora = millis();

  // 1. PULSADOR CON DEBOUNCE (Pin 19)
  bool btnAct = digitalRead(PIN_PUSH);
  if (btnAct == LOW && btnAnt == HIGH && (ahora - btnUltimoTiempo > DEBOUNCE_MS)) {
    btnUltimoTiempo = ahora;
    indiceEstado = (indiceEstado + 1) % 4;
    Serial.print("Estado cambiado a: ");
    Serial.println(estados[indiceEstado]);
  }
  btnAnt = btnAct;

  // 2. DISPLAY (Refresco constante para mostrar los segundos de Uptime)
  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.println("SISTEMA DE MONITOREO");
  display.drawLine(0, 10, 127, 10, SH110X_WHITE);
  
  display.setCursor(0, 25);
  display.print("Estado: ");
  display.setCursor(0, 40);
  display.println(estados[indiceEstado]);
  
  display.setCursor(0, 55);
  display.printf("Uptime: %lu s", ahora / 1000);
  display.display();

  // 3. THINGSPEAK CADA 16 SEGUNDOS
  if (ahora - ultimaVezThingSpeak >= intervaloThingSpeak) {
    float t = dht.readTemperature();
    float h = dht.readHumidity();
    long valorAleatorio = random(100, 501);
    unsigned long segundosUptime = ahora / 1000;

    if (isnan(t) || isnan(h)) {
      Serial.println("Error al leer DHT!");
      t = 0.0; h = 0.0;
    }

    ThingSpeak.setField(1, (float)valorAleatorio);
    ThingSpeak.setField(2, t);
    ThingSpeak.setField(3, h);
    ThingSpeak.setField(4, (long)segundosUptime);
    ThingSpeak.setStatus(estados[indiceEstado]);

    int respuesta = ThingSpeak.writeFields(Channel, APIKey);

    Serial.println("\n--- Reporte ThingSpeak ---");
    Serial.printf("Temp: %.2f | Hum: %.2f\n", t, h);
    Serial.printf("Estado: %s\n", estados[indiceEstado]);

    if (respuesta == 200) {
      Serial.println(">> Grabado correctamente.");
    } else {
      Serial.printf(">> ERROR: %d\n", respuesta);
    }
    ultimaVezThingSpeak = ahora;
  }
}
