#include <WiFi.h>
#include <ThingSpeak.h>
#include <DHT.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SH110X.h>
#include <ArduinoOTA.h>

// --- WIFI ---
const char* ssid     = "Caladux";
const char* password = "carlos123";

// --- THINGSPEAK ---
unsigned long Channel = 3370344;
const char*   APIKey  = "0F6V5EO1Q5K9WTZ6";
WiFiClient client;

// --- DHT ---
#define DHTPIN  33
#define DHTTYPE DHT22
DHT dht(DHTPIN, DHTTYPE);

// --- PULSADOR ---
#define PIN_PUSH 19
bool          btnAnt         = HIGH;
unsigned long btnUltimoTiempo = 0;
const int     DEBOUNCE_MS    = 50;

// --- DISPLAY ---
#define I2C_ADDRESS 0x3C
Adafruit_SH1106G display = Adafruit_SH1106G(128, 64, &Wire, -1);

// --- ESTADOS ---
const char* estados[] = {
  "No disponible",
  "En reparacion",
  "Habilitado",
  "Fuera de servicio"
};
int indiceEstado = 0;

// --- TIEMPO ---
unsigned long ultimaVezThingSpeak = 0;
const unsigned long intervaloThingSpeak = 16000;
unsigned long tUltimoDisplay = 0;

// ================================================================
void mostrarDisplay(unsigned long ahora) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);

  display.setCursor(0, 0);
  display.println("SISTEMA MONITOREO");
  display.drawLine(0, 10, 127, 10, SH110X_WHITE);

  display.setCursor(0, 20);
  display.print("Estado:");
  display.setCursor(0, 32);
  display.println(estados[indiceEstado]);

  display.setCursor(0, 50);
  display.printf("Uptime: %lu s", ahora / 1000);

  display.display();
}

// ================================================================
void setup() {
  Serial.begin(115200);
  pinMode(PIN_PUSH, INPUT_PULLUP);
  dht.begin();
  Wire.begin(21, 22);

  // Display
  if (!display.begin(I2C_ADDRESS, true)) {
    Serial.println("ERROR: Display no responde. Verificar cableado.");
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.println("Iniciando...");
  display.display();

  // WiFi con timeout — no se cuelga para siempre
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  Serial.print("Conectando a WiFi");

  int intentos = 0;
  while (WiFi.status() != WL_CONNECTED && intentos < 20) {
    delay(500);
    Serial.print(".");
    intentos++;

    display.clearDisplay();
    display.setCursor(0, 0);  display.println("Conectando WiFi...");
    display.setCursor(0, 20); display.printf("Intento: %d/20", intentos);
    display.display();
  }
 Serial.printf("\nStatus final: %d\n", WiFi.status());
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi OK! IP: " + WiFi.localIP().toString());
    display.clearDisplay();
    display.setCursor(0, 0);  display.println("WiFi OK!");
    display.setCursor(0, 15); display.println(WiFi.localIP().toString());
    display.display();
    delay(2000);
  } else {
    Serial.println("\nERROR: No se pudo conectar. Verificar SSID/password o usar hotspot.");
    display.clearDisplay();
    display.setCursor(0, 0);  display.println("ERROR WiFi");
    display.setCursor(0, 15); display.println("Verificar red");
    display.setCursor(0, 30); display.println("o usar hotspot");
    display.display();
    delay(3000);
  }

  // OTA
  ArduinoOTA.setHostname("ESP32-Sketch1-Envio");
  ArduinoOTA.onStart([]() {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SH110X_WHITE);
    display.setCursor(0, 20); display.println("  Actualizando OTA...");
    display.setCursor(0, 35); display.println("  No desconectar!");
    display.display();
    Serial.println("OTA: Iniciando...");
  });
  ArduinoOTA.onEnd([]() {
    Serial.println("OTA: Finalizado.");
  });
  ArduinoOTA.onError([](ota_error_t e) {
    Serial.printf("OTA Error [%u]\n", e);
  });
  ArduinoOTA.begin();

  ThingSpeak.begin(client);

  // Primera ejecución inmediata
  ultimaVezThingSpeak = millis() - intervaloThingSpeak;
  tUltimoDisplay      = millis();

  Serial.println("=== SKETCH 1 LISTO ===");
  mostrarDisplay(millis());
}

// ================================================================
void loop() {
  ArduinoOTA.handle();
  unsigned long ahora = millis();

  // --- DISPLAY cada 500ms ---
  if (ahora - tUltimoDisplay >= 500) {
    mostrarDisplay(ahora);
    tUltimoDisplay = ahora;
  }

  // --- PULSADOR sin delay() ---
  bool btnAct = digitalRead(PIN_PUSH);
  if (btnAct == LOW && btnAnt == HIGH && (ahora - btnUltimoTiempo > DEBOUNCE_MS)) {
    btnUltimoTiempo = ahora;
    indiceEstado    = (indiceEstado + 1) % 4;
    Serial.printf("Estado: %s\n", estados[indiceEstado]);
  }
  btnAnt = btnAct;

  // --- RECONEXIÓN WiFi no bloqueante ---
 // --- RECONEXIÓN WiFi no bloqueante ---
  if (WiFi.status() != WL_CONNECTED) {
    static unsigned long tUltimoRecon = 0;
    if (ahora - tUltimoRecon >= 8000) {
      Serial.println("WiFi caido. Reintentando...");
      WiFi.disconnect();
      delay(100);
      WiFi.begin(ssid, password);
      tUltimoRecon = ahora;
    }
    return;
  }

  // --- ENVÍO THINGSPEAK cada 16s ---
  if (ahora - ultimaVezThingSpeak >= intervaloThingSpeak) {
    ultimaVezThingSpeak = ahora;

    float t          = dht.readTemperature();
    float h          = dht.readHumidity();
    long  aleatorio  = random(100, 501);
    long  uptime     = ahora / 1000;

    if (isnan(t) || isnan(h)) {
      Serial.println("ADVERTENCIA: DHT22 no responde. Enviando ceros.");
      t = 0.0; h = 0.0;
    }

    ThingSpeak.setField(1, (float)aleatorio);
    ThingSpeak.setField(2, t);
    ThingSpeak.setField(3, h);
    ThingSpeak.setField(4, uptime);
    ThingSpeak.setStatus(estados[indiceEstado]);

    Serial.println("\n--- ENVIANDO A THINGSPEAK ---");
    Serial.printf("  Aleatorio: %ld\n",     aleatorio);
    Serial.printf("  Temp:      %.2f C\n",  t);
    Serial.printf("  Hum:       %.2f %%\n", h);
    Serial.printf("  Uptime:    %ld s\n",   uptime);
    Serial.printf("  Estado:    %s\n",      estados[indiceEstado]);

    int resp = ThingSpeak.writeFields(Channel, APIKey);
    if (resp == 200) Serial.println("  >> EXITO");
    else             Serial.printf("  >> ERROR HTTP %d\n", resp);
  }
}
