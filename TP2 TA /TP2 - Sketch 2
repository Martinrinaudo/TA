#include <WiFi.h>
#include <ThingSpeak.h>
#include <ArduinoOTA.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SH110X.h>

// --- WIFI (Igual al Sketch 1 para que el salto OTA sea fluido) ---
const char* ssid     = "Caladux";
const char* password = "carlos123";

// --- THINGSPEAK ---
unsigned long Channel = 3370344; 
const char* ReadAPIKey  = "8U8VUIPDHO68RIV9"; 
WiFiClient client;

// --- DISPLAY SH1106 ---
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define I2C_ADDRESS 0x3C
Adafruit_SH1106G display = Adafruit_SH1106G(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// --- VARIABLES ---
float valorAleatorio = 0, temperatura = 0, humedad = 0;
long uptime = 0;
String estado = "Esperando...";

int pantallaActual = 0;
unsigned long ultimaLectura = 0;
const unsigned long intervaloLectura = 16000;
unsigned long ultimoCambioPantalla = 0;
const unsigned long intervaloPantalla = 3000;

bool datosRecibidos = false;

// ================================================================
void mostrarPantalla() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);

  if (!datosRecibidos) {
    display.setCursor(0, 20);
    display.println("Sincronizando");
    display.println("con la nube...");
    display.display();
    return;
  }

  if (pantallaActual == 0) {
    display.setCursor(0, 0);
    display.println("1/3: DATOS GENERALES");
    display.drawLine(0, 10, 127, 10, SH110X_WHITE);
    display.setCursor(0, 25);
    display.printf("Aleatorio: %.0f", valorAleatorio);
    display.setCursor(0, 45);
    display.printf("Uptime: %ld s", uptime);

  } else if (pantallaActual == 1) {
    display.setCursor(0, 0);
    display.println("2/3: AMBIENTE");
    display.drawLine(0, 10, 127, 10, SH110X_WHITE);
    display.setCursor(0, 25);
    display.printf("Temp: %.2f C", temperatura);
    display.setCursor(0, 45);
    display.printf("Hum: %.2f %%", humedad);

  } else if (pantallaActual == 2) {
    display.setCursor(0, 0);
    display.println("3/3: ESTADO NUBE");
    display.drawLine(0, 10, 127, 10, SH110X_WHITE);
    display.setCursor(0, 30);
    display.println(estado);
  }

  display.display();
}

// ================================================================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  // Inicialización Display
  if (!display.begin(I2C_ADDRESS, true)) {
    Serial.println("Error OLED");
  }

  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("SKETCH 2: LECTURA");
  display.println("Conectando WiFi...");
  display.display();

  // WIFI
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  // OTA (Fundamental para volver al Sketch 1 después)
  ArduinoOTA.setHostname("ESP32-Sketch2-Lectura");
  ArduinoOTA.begin();

  ThingSpeak.begin(client);
  ultimoCambioPantalla = millis();
}

// ================================================================
void loop() {
  ArduinoOTA.handle();
  unsigned long ahora = millis();

  // --- ROTACIÓN DE PANTALLAS ---
  if (ahora - ultimoCambioPantalla >= intervaloPantalla) {
    pantallaActual = (pantallaActual + 1) % 3;
    mostrarPantalla();
    ultimoCambioPantalla = ahora;
  }

  // --- LECTURA DE THINGSPEAK ---
  if (ahora - ultimaLectura >= intervaloLectura) {
    if (WiFi.status() == WL_CONNECTED) {
      // Leemos todos los campos de una vez
      int httpCode = ThingSpeak.readMultipleFields(Channel, ReadAPIKey);

      if (httpCode == 200) {
        valorAleatorio = ThingSpeak.getFieldAsFloat(1);
        temperatura    = ThingSpeak.getFieldAsFloat(2);
        humedad        = ThingSpeak.getFieldAsFloat(3);
        uptime         = ThingSpeak.getFieldAsLong(4);
        estado         = ThingSpeak.getStatus();
        datosRecibidos = true;
        Serial.println(">> Datos sincronizados");
      } else {
        Serial.printf("Error ThingSpeak: %d\n", httpCode);
      }
    }
    ultimaLectura = ahora;
  }
}
