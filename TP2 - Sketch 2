#include <WiFi.h>
#include <ThingSpeak.h>
#include <ArduinoOTA.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// --- CONFIGURACIÓN WIFI Y THINGSPEAK ---
const char* ssid = "Wokwi-GUEST";
const char* password = "";
unsigned long Channel = 3365192;
const char* ReadAPIKey = "YG5NS6WNVP60V4M6";
WiFiClient client;

// --- DISPLAY ---
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define I2C_ADDRESS 0x3C
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// --- VARIABLES ---
float valorAleatorio = 0, temperatura = 0, humedad = 0;
long uptime = 0;
String estado = "Esperando datos...";

int pantallaActual = 0;
unsigned long ultimaLectura = 0;
const unsigned long intervaloLectura = 16000;
unsigned long ultimoCambioPantalla = 0;
const unsigned long intervaloPantalla = 3000; // Rota cada 3 segundos

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  if (!display.begin(SSD1306_SWITCHCAPVCC, I2C_ADDRESS)) {
    Serial.println("Error al iniciar OLED");
    while (1);
  }

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0);
  display.println("Conectando WiFi...");
  display.display();

  // --- WIFI ---
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi conectado!");

  // --- CONFIGURACIÓN OTA ---
  ArduinoOTA.setHostname("esp32-thingspeak");
  ArduinoOTA.onStart([]() {
    display.clearDisplay();
    display.setCursor(0, 0);
    display.println("Actualizando OTA...");
    display.display();
  });
  ArduinoOTA.begin();

  ThingSpeak.begin(client);
}

void mostrarPantalla() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  // Divide la información en 3 pantallas para cumplir el requisito de legibilidad
  if (pantallaActual == 0) {
    display.setCursor(0, 0);
    display.println("1/3: DATOS GENERALES");
    display.drawLine(0, 10, 127, 10, WHITE);
    display.setCursor(0, 20);
    display.printf("Aleatorio: %.0f\n", valorAleatorio);
    display.setCursor(0, 35);
    display.printf("Uptime: %ld seg\n", uptime);
  } else if (pantallaActual == 1) {
    display.setCursor(0, 0);
    display.println("2/3: AMBIENTE");
    display.drawLine(0, 10, 127, 10, WHITE);
    display.setCursor(0, 20);
    display.printf("Temp: %.2f C\n", temperatura);
    display.setCursor(0, 35);
    display.printf("Hum: %.2f %%\n", humedad);
  } else if (pantallaActual == 2) {
    display.setCursor(0, 0);
    display.println("3/3: ESTADO");
    display.drawLine(0, 10, 127, 10, WHITE);
    display.setCursor(0, 20);
    display.println(estado);
  }
  display.display();
}

void loop() {
  // Indispensable mantener OTA a la escucha
  ArduinoOTA.handle();
  unsigned long ahora = millis();

  // Rotación automática de las pantallas del display
  if (ahora - ultimoCambioPantalla >= intervaloPantalla) {
    pantallaActual = (pantallaActual + 1) % 3;
    mostrarPantalla();
    ultimoCambioPantalla = ahora;
  }

  // Lectura optimizada en bloque desde ThingSpeak
  if (ahora - ultimaLectura >= intervaloLectura) {
    if (WiFi.status() == WL_CONNECTED) {
      Serial.println("\nConsultando ThingSpeak...");
      int httpCode = ThingSpeak.readMultipleFields(Channel, ReadAPIKey);

      if (httpCode == 200) {
        valorAleatorio = ThingSpeak.getFieldAsFloat(1);
        temperatura = ThingSpeak.getFieldAsFloat(2);
        humedad = ThingSpeak.getFieldAsFloat(3);
        uptime = ThingSpeak.getFieldAsLong(4);
        estado = ThingSpeak.getStatus();
        Serial.println(">> Lectura exitosa. Pantalla actualizada.");
      } else {
        Serial.printf(">> Error de lectura HTTP. Codigo: %d\n", httpCode);
      }
    }
    ultimaLectura = ahora;
  }
}